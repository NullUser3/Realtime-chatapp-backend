# Node dependencies
node_modules/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build / output folders (if you compile/transpile)
dist/
build/

# OS / Editor files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE / editor settings
.vscode/
.idea/

# Optional coverage reports
coverage/

# Certificates / keys (never commit real SSL certs)
*.pem
certs/

# Misc
*.log